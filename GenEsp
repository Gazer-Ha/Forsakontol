local cref = cloneref or function(ref) return ref end
local ts = cref(game:GetService("TweenService"))
local ws = cref(workspace)

local gens, guis = {}, {}

local function getColors(p)
    local progress = math.clamp(p / 100, 0, 1)
    
    -- Color transition logic:
    if progress < 1 then
        return Color3.new(1, progress, 0) -- Red to Yellow
    else
        return Color3.new(0, 1, 0) -- Green at 100%
    end
end

local function updateUI(gen)
    local prog = gen:FindFirstChild("Progress")
    local gui = guis[gen]
    
    if prog and gui then
        local pValue = prog.Value
        local clampedP = math.clamp(pValue / 100, 0, 1)
        local fColor = getColors(pValue)
        
        local barBg = gui:FindFirstChild("BarBg")
        local fill = barBg and barBg:FindFirstChild("Fill")
        local textLbl = gui:FindFirstChild("TextLabel")
        
        if fill and textLbl then
            local speed = math.clamp(1 - clampedP, 0.2, 0.5)
            
            -- Update Text
            textLbl.Text = "Generator - " .. math.floor(pValue) .. "%"
            textLbl.TextColor3 = fColor:Lerp(Color3.new(1,1,1), 0.5) -- Make text match color slightly
            
            -- Tween Bar Size and Color
            local tf = ts:Create(fill, TweenInfo.new(speed, Enum.EasingStyle.Linear), {
                Size = UDim2.new(clampedP, 0, 1, 0),
                BackgroundColor3 = fColor
            })
            tf:Play()
            
            tf.Completed:Connect(function()
                tf:Destroy()
            end)
        end
    end
end

local function monitorProgress(gen)
    local prog = gen:FindFirstChild("Progress")
    if not prog then return end

    -- Constantly check for changes every 0.1 seconds
    task.spawn(function()
        while gens[gen] and prog do
            updateUI(gen)
            task.wait(0.1) -- Fast detection
        end
    end)
end

local function addGen(obj)
    if obj:IsA("Model") and obj.Name == "Generator" and not gens[obj] then
        -- Find a part to attach the UI to (PrimaryPart is preferred)
        local attachPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if not attachPart then return end -- Skip if no physical part exists
        
        gens[obj] = true
        
        -- Create BillboardGui
        local bb = Instance.new("BillboardGui")
        bb.Name = "ProgressUI"
        bb.Adornee = attachPart
        bb.Size = UDim2.new(5, 0, 1.5, 0)
        bb.StudsOffset = Vector3.new(0, 4, 0) -- Float 4 studs above the part
        bb.AlwaysOnTop = true
        bb.MaxDistance = 200
        
        -- Create TextLabel
        local textLbl = Instance.new("TextLabel", bb)
        textLbl.Name = "TextLabel"
        textLbl.Size = UDim2.new(1, 0, 0.6, 0)
        textLbl.BackgroundTransparency = 1
        textLbl.TextScaled = true
        textLbl.Font = Enum.Font.GothamBold
        textLbl.TextStrokeTransparency = 0.2
        textLbl.TextColor3 = Color3.new(1, 1, 1)
        textLbl.Text = "Generator - 0%"
        
        -- Create Background Bar
        local barBg = Instance.new("Frame", bb)
        barBg.Name = "BarBg"
        barBg.Size = UDim2.new(1, 0, 0.3, 0)
        barBg.Position = UDim2.new(0, 0, 0.7, 0)
        barBg.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
        barBg.BackgroundTransparency = 0.3
        
        local uiCornerBg = Instance.new("UICorner", barBg)
        uiCornerBg.CornerRadius = UDim.new(1, 0)
        
        -- Create Fill Bar
        local fill = Instance.new("Frame", barBg)
        fill.Name = "Fill"
        fill.Size = UDim2.new(0, 0, 1, 0)
        fill.BackgroundColor3 = Color3.new(1, 0, 0)
        
        local uiCornerFill = Instance.new("UICorner", fill)
        uiCornerFill.CornerRadius = UDim.new(1, 0)
        
        bb.Parent = obj
        guis[obj] = bb
        
        local prog = obj:FindFirstChild("Progress")
        if prog and prog:IsA("NumberValue") then
            monitorProgress(obj) -- Start the manual detection loop
            updateUI(obj)
        end
    end
end

local function removeGen(obj)
    if gens[obj] then
        gens[obj] = nil
        if guis[obj] then 
            guis[obj]:Destroy() 
            guis[obj] = nil 
        end
    end
end

local function validateGenerators()
    local m = ws:FindFirstChild("Map")
    local gm = m and m:FindFirstChild("Ingame") and m.Ingame:FindFirstChild("Map")
    
    if gm then
        -- Add missing generators
        for _, obj in ipairs(gm:GetChildren()) do
            if obj:IsA("Model") and obj.Name == "Generator" and not gens[obj] then
                addGen(obj)
            end
        end
        
        -- Remove invalid generators
        for obj in pairs(gens) do
            if not obj or not obj.Parent or obj.Parent ~= gm then
                removeGen(obj)
            end
        end
    end
end

-- Loop to continuously check for new or missing generators
task.spawn(function()
    while true do
        validateGenerators()
        task.wait(1) -- Check every 1 second
    end
end)
